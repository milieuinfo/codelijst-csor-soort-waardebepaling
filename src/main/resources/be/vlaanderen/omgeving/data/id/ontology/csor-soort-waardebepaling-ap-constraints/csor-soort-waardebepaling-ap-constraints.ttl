@prefix owl:           <http://www.w3.org/2002/07/owl#> .
@prefix xhv:           <http://www.w3.org/1999/xhtml/vocab#> .
@prefix xsd:           <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:          <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs:          <http://www.w3.org/2000/01/rdf-schema#> .
@prefix omg_dataset:   <https://data.omgeving.vlaanderen.be/id/dataset/> .
@prefix dct:           <http://purl.org/dc/terms/> .
@prefix sh:            <http://www.w3.org/ns/shacl#> .
@prefix omg_ont:       <https://data.omgeving.vlaanderen.be/id/ontology/> .
@prefix omg_ag_cl:     <https://data.omgeving.vlaanderen.be/id/person/codelijst/> .
@prefix omg_voc:       <https://data.omgeving.vlaanderen.be/ns/> .
@prefix vl_org:        <http://data.vlaanderen.be/id/organisatie/> .
@prefix xkos:          <http://rdf-vocabulary.ddialliance.org/xkos#> .
@prefix omg_ps:        <https://data.omgeving.vlaanderen.be/id/propertyshape/> .
@prefix rdf:           <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix ons:           <https://data.omgeving.vlaanderen.be/id/nodeshape/> .
@prefix schema:        <http://schema.org/> .
@prefix foaf:          <http://xmlns.com/foaf/0.1/> .
@prefix dcat:  <http://www.w3.org/ns/dcat#> .

omg_ont:csor-soort-waardebepaling-ap-constraints
    a               owl:Ontology ;
    rdfs:comment
                    "Specifieert hoe de data in de codelijst van CSOR soorten waardebepaling te encoderen in RDF (i.e. RDF termen, kardinaliteiten,...)."@en ;
    rdfs:label      "CSOR Soort Waardebepaling AP Constraints"@en ;
    dct:abstract    "Het CSOR soort waardebepaling applicatieprofiel specifieert de RDF termen (klassen en properties) en bijhorende constraints die gebruikt worden voor het beschrijven van soorten waardebepaling in het Chemische Stoffen en Omgevingsparameters-Register (CSOR). Het maakt hierbij zoveel mogelijk gebruik van bestaande termen (klassen en properties) uit bestaande vocabularia zoals skos en csor."@en ;
    dct:alternative "CSOR Soort Waardebepaling AP Shapes"@en ;
    dct:creator     omg_ag_cl:creator ;
    dct:description "Dit is de SHACL encodering van het applicatieprofiel van een CSOR soort waardebepaling."@en ;
    dct:issued      "2026-05-19"^^xsd:date ;
    dct:title       "CSOR Soort Waardebepaling AP Constraints"@en ;
    xkos:belongsTo  omg_dataset:codelijst-csor-soort-waardebepaling ;
    xhv:last        omg_voc:csor-soort-waardebepaling-ap-constraints ;
    owl:sameAs      omg_voc:csor-soort-waardebepaling-ap-constraints ;
    owl:versionInfo "Versie 1.0.0  mei 2026"@en .


omg_voc:csor-soort-waardebepaling-ap-constraints
    a          owl:Ontology ;
    rdfs:label "CSOR Soort Waardebepaling AP Constraints"@en ;
    owl:sameAs omg_ont:csor-soort-waardebepaling-ap-constraints .

omg_ag_cl:creator
    rdfs:label "Ontwikkelaar codelijst"@en ;
    schema:affiliation vl_org:OVO003749 ;
    a foaf:Person;
    foaf:firstName "Geert";
    foaf:lastName "Van Haute";
    foaf:mbox <mailto:geert.vanhaute@vlaanderen.be>.

# Node Shapes
ons:schema
    a                sh:NodeShape ;
    rdfs:label       "conceptschema van CSOR soorten waardebepaling"@en ;
    sh:name          "conceptschema van CSOR soorten waardebepaling"@en ;
    sh:description   "Het schema waarbinnen de CSOR soorten waardebepaling gedefinieerd zijn"@en ;
    rdfs:isDefinedBy omg_ont:csor-soort-waardebepaling-ap-constraints, omg_voc:csor-soort-waardebepaling-ap-constraints ;
    sh:property      omg_ps:conceptscheme_prefLabel, omg_ps:schema_hasTopConcept,
                     omg_ps:definition, omg_ps:rdf_type;

    sh:targetClass   skos:ConceptScheme .



ons:collection
    a                sh:NodeShape ;
    rdfs:label       "verzameling"@en ;
    sh:name          "verzameling"@en ;
    sh:description   "Verzamelingen bundelen CSOR soorten waardebepaling met gelijkaardige eigenschappen."@en ;
    rdfs:isDefinedBy omg_ont:csor-soort-waardebepaling-ap-constraints, omg_voc:csor-soort-waardebepaling-ap-constraints ;
    sh:property      omg_ps:prefLabel, omg_ps:collection_member,
                     omg_ps:inScheme, omg_ps:rdf_type;

    sh:targetClass   skos:Collection .



ons:soort-waardebepaling
    a                sh:NodeShape ;
    rdfs:label       "soort waardebepaling"@en ;
    sh:name          "soort waardebepaling"@en ;
    sh:description   "De manier (of de groep van compatibele manieren) waarop een waarde wordt toegekend voor de observatie van het geobserveerde kenmerk. Verschillende soorten waardebepaling leveren fundamenteel andere resultaten op en zijn dus onderling onvergelijkbaar."@en ;
    rdfs:comment     ""@en ;
    rdfs:isDefinedBy omg_ont:csor-soort-waardebepaling-ap-constraints, omg_voc:csor-soort-waardebepaling-ap-constraints ;
    sh:property      omg_ps:notation, omg_ps:inScheme,
                     omg_ps:definition,
                     omg_ps:prefLabel,
                     omg_ps:topConceptOf,
                     omg_ps:rdf_type ;

    sh:targetClass   skos:Concept .



# Property Shapes

omg_ps:rdf_type
    a                sh:PropertyShape ;
    rdfs:label       "rdf type"@en ;
    sh:name          "rdf type"@en ;
    sh:description   "Aanduiding dat een bron een instantie van een bepaalde klasse is."@en ;
    rdfs:isDefinedBy omg_ont:csor-soort-waardebepaling-ap-constraints, omg_voc:csor-soort-waardebepaling-ap-constraints ;

    sh:minCount      1 ;
    sh:nodeKind      sh:IRI ;
    sh:path          rdf:type .


omg_ps:topConceptOf
    a                sh:PropertyShape ;
    rdfs:label       "topconcept van"@en ;
    sh:name          "topconcept van"@en ;
    sh:description   "De relatie tussen een concept en het schema, waarvan het een topconcept is."@en ;
    rdfs:isDefinedBy omg_ont:csor-soort-waardebepaling-ap-constraints, omg_voc:csor-soort-waardebepaling-ap-constraints ;
    sh:class         skos:ConceptScheme ;
    sh:maxCount      1 ;
    sh:nodeKind      sh:IRI ;
    sh:path          skos:topConceptOf .


omg_ps:collection_member
    a                sh:PropertyShape ;
    rdfs:label       "onderdeel"@en ;
    sh:name          "onderdeel"@en ;
    sh:description   "Een collectie heeft minstens 1 onderdeel."@en ;
    rdfs:isDefinedBy omg_ont:csor-soort-waardebepaling-ap-constraints, omg_voc:csor-soort-waardebepaling-ap-constraints ;
    sh:class         skos:Concept ;
    sh:minCount      1 ;
    sh:nodeKind      sh:IRI ;
    sh:path          skos:member .


omg_ps:notation
    a                sh:PropertyShape ;
    rdfs:label       "notatie"@en ;
    sh:name          "notatie"@en ;
    sh:description   "Een notatie, ook wel symbool genoemd, is een reeks tekens die wordt gebruikt om een soort waardebepaling op unieke wijze te identificeren binnen de context van dit schema."@en ;
    rdfs:isDefinedBy omg_ont:csor-soort-waardebepaling-ap-constraints, omg_voc:csor-soort-waardebepaling-ap-constraints ;
    sh:datatype      xsd:string ;
    sh:nodeKind      sh:Literal ;
    sh:path          skos:notation .


omg_ps:schema_hasTopConcept
    a                sh:PropertyShape ;
    rdfs:label       "heeft topconcept"@en ;
    sh:name          "heeft topconcept"@en ;
    sh:description   "Verbindt een conceptschema met een concept dat bovenaan in een 'broader/narrower' hierarchie staat en voorziet aldus een ingang tot die hierarchie."@en ;
    rdfs:isDefinedBy omg_ont:csor-soort-waardebepaling-ap-constraints, omg_voc:csor-soort-waardebepaling-ap-constraints ;
    sh:class         skos:Concept ;
    sh:minCount      1 ;
    sh:nodeKind      sh:IRI ;
    sh:path          skos:hasTopConcept .


omg_ps:definition
    a                sh:PropertyShape ;
    rdfs:label       "definitie"@en ;
    sh:name          "definitie"@en ;
    sh:description   "Een uitspraak over de betekenis van het concept, de collectie of het schema."@en ;
    rdfs:isDefinedBy omg_ont:csor-soort-waardebepaling-ap-constraints, omg_voc:csor-soort-waardebepaling-ap-constraints ;
    sh:datatype      rdf:langString ;
    sh:languageIn    ( "nl" "en" ) ;
    sh:maxCount      2 ;
    sh:nodeKind      sh:Literal ;
    sh:path          skos:definition .


omg_ps:prefLabel
    a                sh:PropertyShape ;
    rdfs:label       "voorkeurslabel"@en ;
    sh:name          "voorkeurslabel"@en ;
    sh:description   "Het voorkeurslabel in de Nederlandse taal. Slechts 1 voorkeurslabel is toegelaten."@en ;
    rdfs:isDefinedBy omg_ont:csor-soort-waardebepaling-ap-constraints, omg_voc:csor-soort-waardebepaling-ap-constraints ;
    sh:datatype      rdf:langString ;
    sh:languageIn    ( "nl" ) ;
    sh:maxCount      1 ;
    sh:minCount      1 ;
    sh:nodeKind      sh:Literal ;
    sh:path          skos:prefLabel .


omg_ps:conceptscheme_prefLabel
    a                sh:PropertyShape ;
    rdfs:label       "voorkeurslabel"@en ;
    sh:name          "voorkeurslabel"@en ;
    sh:description   "Het voorkeurslabel."@en ;
    rdfs:isDefinedBy omg_ont:csor-soort-waardebepaling-ap-constraints, omg_voc:csor-soort-waardebepaling-ap-constraints ;
    sh:datatype      rdf:langString ;
    sh:languageIn    ( "en" "nl" ) ;
    sh:uniqueLang true ;
    sh:maxCount      2 ;
    sh:minCount      1 ;
    sh:nodeKind      sh:Literal ;
    sh:path          skos:prefLabel .

omg_ps:inScheme
    a                sh:PropertyShape ;
    rdfs:label       "is in schema"@en ;
    sh:name          "is in schema"@en ;
    sh:description   "Drukt de relatie uit tussen een 'resource' en het schema dat het bevat."@en ;
    rdfs:isDefinedBy omg_ont:csor-soort-waardebepaling-ap-constraints, omg_voc:csor-soort-waardebepaling-ap-constraints ;
    sh:class         skos:ConceptScheme ;
    sh:maxCount      1 ;
    sh:minCount      1 ;
    sh:nodeKind      sh:IRI ;
    sh:path          skos:inScheme .
